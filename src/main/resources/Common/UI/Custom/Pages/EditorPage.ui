// Generated by Hytale UI Builder (https://hytale.ellie.au).
$C = "../Common.ui";

Group #Root {
    LayoutMode: Top;
    Anchor: (Full: 0);

    Group #TopBar {
        LayoutMode: Left;
        Anchor: (Height: 40);
        TextField #FileNameInput {
            FlexWeight: 1;
            PlaceholderText: "Filename";
            Background: $C.@InputBoxBackground;
        }
        $C.@TextButton #SaveButton {
            Anchor: (Width: 120);
            Text: "Save";
        }
    }

    Group #Main {
        LayoutMode: Left;
        Anchor: (Full: 0, Height: 900);
        Group #FileList {
            LayoutMode: Top;
            Anchor: (Width: 250);
        }
        MultilineTextField #EditorField {
            FlexWeight: 1;
            Style: $C.@DefaultInputFieldStyle;
            PlaceholderStyle: $C.@DefaultInputFieldPlaceholderStyle;
            Background: $C.@InputBoxBackground;
            AutoGrow: false;
        }
    }

}
